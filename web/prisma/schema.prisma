// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum AccessStatus {
  PENDING
  APPROVED
  REJECTED
}

model AccessRequest {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  locale    String
  name      String
  email     String
  intent    String
  status    AccessStatus @default(PENDING)
}
